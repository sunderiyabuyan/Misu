{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "isolatedModules": true,
    "rootDir": ".",
    "outDir": "./dist",

    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "sourceMap": true
  },
  "include": ["src", "prisma"],
  "exclude": ["node_modules", "dist"]
}
